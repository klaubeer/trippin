# Normaliza line endings para LF no repositório
* text=auto eol=lf

# Arquivos que devem sempre ser LF
*.py      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.env*    text eol=lf
*.sh      text eol=lf
*.sql     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
Dockerfile text eol=lf

# Binários — não normalizar
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
