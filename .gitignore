# ─────────────────────────────────────────────────────────────────
# Trippin' — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Segredos e variáveis de ambiente ─────────────────────────────
.env
.env.*
!.env.example          # manter o template de exemplo no repo

frontend/.env.local
frontend/.env.*.local

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Build / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking / linting
.mypy_cache/
.ruff_cache/
.pytype/

# ── Node / Frontend ───────────────────────────────────────────────
node_modules/
frontend/node_modules/
.next/
frontend/.next/
frontend/out/
frontend/build/
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Banco de dados local ──────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Docker ───────────────────────────────────────────────────────
*.override.yml
docker-compose.override.yml

# ── Migrações compiladas ──────────────────────────────────────────
alembic/versions/__pycache__/

# ── IDE / Editores ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sublime-workspace
*.sublime-project
.atom/

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Chaves e certificados ─────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/

# ── Coverage / testes ────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Temporários ──────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
.cache/

# ── Arquivos internos de desenvolvimento AI ───────────────────────
CLAUDE.md
AGENTS.md
frontend/CLAUDE.md
frontend/AGENTS.md
memory/

# ── Configurações locais do Claude Code ───────────────────────────
.claude/

# ── Vídeos de background (arquivos grandes — não versionar) ──────────
frontend/public/videos/*.mp4
frontend/public/videos/*.webm
frontend/public/videos/*.mov
